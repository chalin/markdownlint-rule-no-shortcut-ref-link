{
  "name": "markdownlint-rule-no-shortcut-ref-link",
  "version": "0.3.1",
  "description": "A markdownlint rule that flags shortcut reference links and converts them to collapsed form",
  "license": "Apache-2.0",
  "author": "chalin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chalin/markdownlint-rule-no-shortcut-ref-link.git"
  },
  "homepage": "https://github.com/chalin/markdownlint-rule-no-shortcut-ref-link",
  "bugs": "https://github.com/chalin/markdownlint-rule-no-shortcut-ref-link/issues",
  "type": "module",
  "exports": "./index.mjs",
  "scripts": {
    "check:format": "npx prettier --check .",
    "check:markdown": "npx markdownlint-cli2 \"**/*.md\"",
    "check:spelling": "npx cspell --no-progress \"**/*.{md,mjs}\"",
    "check": "npm run check:format && npm run check:markdown && npm run check:spelling",
    "fix:format": "npx prettier --write .",
    "fix:markdown": "npm run check:markdown -- --fix",
    "fix": "npm run fix:format && npm run fix:markdown",
    "test-and-check": "npm run test-only && npm run check",
    "test-and-fix": "npm run fix && npm run test-and-check",
    "test-only": "node --test",
    "test": "npm run test-and-check",
    "update:packages": "npx npm-check-updates --dep dev,optional -u"
  },
  "files": [
    "index.mjs",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "markdownlint-rule",
    "markdownlint",
    "markdown",
    "links",
    "lint"
  ],
  "peerDependencies": {
    "markdownlint-rule-helpers": ">=0.27.0"
  },
  "devDependencies": {
    "cspell": "^9.6.4",
    "prettier": "3.8.1",
    "markdownlint": "^0.40.0",
    "markdownlint-cli2": "^0.21.0",
    "markdownlint-rule-helpers": "^0.30.0",
    "npm-check-updates": "^19.4.1"
  }
}
